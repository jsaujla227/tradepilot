# =============================================================================
# TradePilot — environment variables
# Copy to `.env.local` for local dev. Set the same values in Vercel for prod.
# Variables WITHOUT NEXT_PUBLIC_ are server-only and never reach the browser.
# =============================================================================

# --- Supabase (added in M3) -------------------------------------------------
# Browser + server (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS. Used solely by `lib/supabase/admin.ts` from
# `app/api/cron/*` and `scripts/*`. Never import from anywhere else.
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (added in M5, via Vercel Marketplace) --------------------
# Server-only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Finnhub (added in M5, market data only) --------------------------------
# Server-only. Free tier covers US-stock /quote at 60 calls/min — plenty for
# a single-user cockpit on a 60s cache. Sign up at https://finnhub.io to get
# a key (works from Canada; no funded account required).
# Used for: real-time quote prices, earnings calendar, news, analyst consensus.
FINNHUB_API_KEY=

# --- Massive.com (added in M19, formerly Polygon.io) ------------------------
# Server-only. Massive.com rebranded from Polygon.io on Oct 30, 2025; existing
# Polygon API keys continue to work. Sign up at https://massive.com.
# Used for: historical OHLC bars and market-open/holiday detection (the agent
# and position-monitor crons skip runs when the US market is closed).
MASSIVE_API_KEY=

# --- Alpha Vantage (added in M19, fundamentals + technicals) ----------------
# Server-only. Free tier: 5 calls/min, 500/day. Sign up at https://www.alphavantage.co.
# Used for: company fundamentals (P/E, EPS, market cap, beta), RSI and MACD
# indicators. Cached aggressively (24h fundamentals, 1h indicators) so the
# free tier suffices for a single-user cockpit. The position monitor uses
# RSI > 75 as an extra take-profit exit signal alongside stop-loss.
ALPHA_VANTAGE_API_KEY=

# --- AWS Bedrock (added in M10, replaces direct Anthropic API key) ----------
# Server-only. Used for Claude 3.5 Sonnet (explain) and Claude 3 Opus (monthly
# journal review) via Amazon Bedrock in us-west-2.
# IAM user needs: bedrock:InvokeModel on the Claude models in your region.
# Create an IAM user → Attach policy AmazonBedrockFullAccess → generate keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
# Full inference profile ARN from AWS Bedrock console (includes your account ID)
BEDROCK_MODEL_ID=arn:aws:bedrock:us-east-2:YOUR_ACCOUNT_ID:inference-profile/global.anthropic.claude-opus-4-6-v1

# --- Cron auth (added in M10/M11) -------------------------------------------
# Server-only. Required header on every cron route: `Authorization: Bearer <this>`.
# Generate with: `openssl rand -hex 32`
CRON_SECRET=
